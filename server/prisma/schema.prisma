generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Interval {
  ONE_TIME
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model Account {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balanceSnapshots  BalanceSnapshot[]
  incomeSources     IncomeSource[]
  plannedExpenses   PlannedExpense[]
  incomingTransfers PlannedExpense[] @relation("TransferTarget")
  actualSpends      ActualSpend[]
}

model BalanceSnapshot {
  id        String   @id @default(uuid())
  amount    Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String

  @@index([accountId])
}

model IncomeSource {
  id        String   @id @default(uuid())
  name      String
  amount    Float
  interval  Interval
  startDate DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String

  @@index([accountId])
}

model PlannedExpense {
  id                  String            @id @default(uuid())
  name                String
  amount              Float
  interval            Interval
  startDate           DateTime
  endDate             DateTime?
  active              Boolean           @default(true)
  category            String?
  isVariable          Boolean           @default(false)
  isTransfer          Boolean           @default(false)
  transferToAccount   Account?          @relation("TransferTarget", fields: [transferToAccountId], references: [id], onDelete: SetNull)
  transferToAccountId String?
  priceAdjustments    PriceAdjustment[]
  actualSpends        ActualSpend[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  account             Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId           String

  @@index([accountId])
  @@index([transferToAccountId])
}

model PriceAdjustment {
  id        String         @id @default(uuid())
  expense   PlannedExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  expenseId String
  amount    Float
  startDate DateTime
  note      String?
  createdAt DateTime       @default(now())

  @@index([expenseId])
}

model ActualSpend {
  id                String          @id @default(uuid())
  date              DateTime
  amount            Float
  note              String?
  category          String?
  forecastExpense   PlannedExpense? @relation(fields: [forecastExpenseId], references: [id], onDelete: SetNull)
  forecastExpenseId String?
  account           Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId         String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([accountId])
  @@index([accountId, date])
  @@index([forecastExpenseId])
}

model CategoryColor {
  name        String @id
  color       String @default("#ef4444")
  description String @default("")
}
