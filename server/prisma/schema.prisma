generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Interval {
  ONE_TIME
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model BalanceSnapshot {
  id        String   @id @default(uuid())
  amount    Float
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model IncomeSource {
  id        String   @id @default(uuid())
  name      String
  amount    Float
  interval  Interval
  startDate DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlannedExpense {
  id        String   @id @default(uuid())
  name      String
  amount    Float
  interval  Interval
  startDate DateTime
  endDate   DateTime?
  active    Boolean  @default(true)
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
